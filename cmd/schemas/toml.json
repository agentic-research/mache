{
  "version": "v1",
  "nodes": [
    {
      "name": "tables",
      "selector": "$",
      "children": [
        {
          "name": "{{.name}}",
          "selector": "(table (bare_key) @name) @scope",
          "files": [
            {
              "name": "source",
              "content_template": "{{.scope}}"
            }
          ]
        }
      ]
    },
    {
      "name": "array_tables",
      "selector": "$",
      "children": [
        {
          "name": "{{.name}}",
          "selector": "(table_array_element (bare_key) @name) @scope",
          "files": [
            {
              "name": "source",
              "content_template": "{{.scope}}"
            }
          ]
        }
      ]
    }
  ]
}
